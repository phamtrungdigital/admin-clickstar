# Supabase — copy to .env.local and fill in
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@clickstar.vn

# ZNS provider (Zalo OA or trung gian)
ZNS_API_BASE_URL=
ZNS_API_KEY=
ZNS_OA_ID=

# n8n webhook base
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
